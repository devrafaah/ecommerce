{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",                                    
    "outDir": "lib",                                   
    "sourceMap": true,                                
    "noEmitOnError": true,
    "noUnusedLocals": true,                             
    "noImplicitReturns": true,
    "strictNullChecks": true,                           
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true                               
  },
  "compileOnSave": true,
  "include": ["src/**/*"],
  "exclude": ["**/*.spec.ts"]
}
